# Copy to .env and fill in your values (.env is gitignored).
# Used by deployment/deploy_order_agent.sh and the LangChain order agent.

# Target GCP project and region for the order-support A2A deployment.
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: model for the LangChain order agent (defaults to gemini-flash-latest).
# MODEL=gemini-flash-latest
