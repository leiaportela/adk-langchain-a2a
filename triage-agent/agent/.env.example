# Copy to .env (gitignored). Lives in agent/ so `adk deploy` bundles it and
# load_dotenv() picks it up (deployed and in local playground).
#
# Order-support provider's agent-card URL (note the /a2a/v1/card path):
#   https://us-central1-aiplatform.googleapis.com/v1beta1/projects/<PROJECT_NUMBER>/locations/us-central1/reasoningEngines/<ENGINE_ID>/a2a/v1/card
ORDER_SUPPORT_A2A_CARD=
